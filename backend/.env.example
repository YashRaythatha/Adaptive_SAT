# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/adaptive_sat

# OpenAI (required for question generation and judge on difficulty 4-5)
# OPENAI_API_KEY=sk-...

# Admin key for /api/admin/* endpoints (send as header X-ADMIN-KEY)
# ADMIN_KEY=your-secret-admin-key

# Exam behavior (optional)
# EXAM_ROUTE_THRESHOLD=0.65
# EXAM_FIRST_EXAM_NO_REPEAT_UNTIL_SESSIONS=20
